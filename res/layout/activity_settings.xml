<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

                <Button
                    android:id="@+id/settings_back_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/button_secondary"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:text="@string/settings_back"
                    android:textColor="@color/accent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_screen_title"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_screen_subtitle"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_appearance_title"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/settings_theme_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_theme_system"
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/settings_theme_system_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/button_primary"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:text="@string/theme_system"
                    android:textColor="@color/button_primary_text" />

                <Button
                    android:id="@+id/settings_theme_light_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_secondary"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:text="@string/theme_light"
                    android:textColor="@color/accent" />

                <Button
                    android:id="@+id/settings_theme_dark_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_secondary"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:text="@string/theme_dark"
                    android:textColor="@color/accent" />
            </LinearLayout>

            <TextView
                android:id="@+id/settings_language_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_language_system"
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/settings_language_system_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/button_primary"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:text="@string/language_system"
                    android:textColor="@color/button_primary_text" />

                <Button
                    android:id="@+id/settings_language_ru_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_secondary"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:text="@string/language_ru"
                    android:textColor="@color/accent" />

                <Button
                    android:id="@+id/settings_language_en_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_secondary"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:text="@string/language_en"
                    android:textColor="@color/accent" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_permissions_title"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/settings_permissions_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_permissions_intro"
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/settings_root_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/permission_root_missing"
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <Button
                android:id="@+id/settings_request_root_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_secondary"
                android:elevation="0dp"
                android:stateListAnimator="@null"
                android:text="@string/permission_root_button"
                android:textColor="@color/accent" />

            <TextView
                android:id="@+id/settings_notifications_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/permission_notifications_missing"
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <Button
                android:id="@+id/settings_notifications_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_secondary"
                android:elevation="0dp"
                android:stateListAnimator="@null"
                android:text="@string/permission_notifications_button"
                android:textColor="@color/accent" />

            <TextView
                android:id="@+id/settings_files_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/permission_files_missing"
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <Button
                android:id="@+id/settings_files_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_secondary"
                android:elevation="0dp"
                android:stateListAnimator="@null"
                android:text="@string/permission_files_button"
                android:textColor="@color/accent" />

            <TextView
                android:id="@+id/settings_overlay_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/permission_overlay_missing"
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <Button
                android:id="@+id/settings_overlay_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_secondary"
                android:elevation="0dp"
                android:stateListAnimator="@null"
                android:text="@string/permission_overlay_button"
                android:textColor="@color/accent" />

            <TextView
                android:id="@+id/settings_admin_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/permission_admin_missing"
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <Button
                android:id="@+id/settings_admin_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_secondary"
                android:elevation="0dp"
                android:stateListAnimator="@null"
                android:text="@string/permission_admin_button"
                android:textColor="@color/accent" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_section_title"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/settings_clamscan_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/hint_clamscan_path"
                android:inputType="textNoSuggestions" />

            <EditText
                android:id="@+id/settings_freshclam_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/hint_freshclam_path"
                android:inputType="textNoSuggestions" />

            <EditText
                android:id="@+id/settings_database_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/hint_database_path"
                android:inputType="textNoSuggestions" />

            <EditText
                android:id="@+id/settings_target_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/hint_target_path"
                android:inputType="textNoSuggestions" />

            <EditText
                android:id="@+id/settings_quarantine_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/hint_quarantine_path"
                android:inputType="textNoSuggestions" />

            <CheckBox
                android:id="@+id/settings_auto_update_checkbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/auto_update_label"
                android:textColor="@color/text_secondary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/settings_save_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/button_primary"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:text="@string/save_button"
                    android:textColor="@color/button_primary_text" />

                <Button
                    android:id="@+id/settings_reset_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_secondary"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:text="@string/reset_defaults_button"
                    android:textColor="@color/accent" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_ignored_title"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/settings_ignored_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/ignored_summary_default"
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <Button
                android:id="@+id/settings_clear_ignored_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_secondary"
                android:elevation="0dp"
                android:stateListAnimator="@null"
                android:text="@string/clear_ignored_button"
                android:textColor="@color/accent" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
